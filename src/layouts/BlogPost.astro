---
import Layout from "./Layout.astro";
import { Icon } from "astro-icon/components";

interface Props {
    frontmatter: {
        title: string;
        pubDate: string;
        description: string;
        image?: {
            url: string;
            alt: string;
        };
        tags?: string[];
    };
}

const { frontmatter } = Astro.props;

const formatDate = (date: Date) => {
    return new Intl.DateTimeFormat("en-US", {
        year: "numeric",
        month: "long",
        day: "numeric",
    }).format(date);
};
---

<Layout>
    <div class="max-w-3xl mx-auto pt-14 pb-16">
        <a
            href="/writing"
            class="inline-flex items-center gap-[0.4rem] text-[0.85rem] text-muted no-underline tracking-[0.03em] mb-10 transition-colors duration-200 hover:text-accent"
        >
            <Icon
                name="iconamoon--arrow-right-2-bold"
                class="w-4 h-4 rotate-180 -translate-y-px"
                aria-hidden="true"
            />
            Back to writing
        </a>

        <article>
            <header class="mb-10 pb-8 border-b border-line">
                <h1 class="font-serif text-[2.75rem] font-normal text-base leading-[1.2] mb-4">
                    {frontmatter.title}
                </h1>
                <div class="text-[0.8rem] tracking-[0.1em] text-muted mb-3">
                    <time datetime={frontmatter.pubDate}>
                        {formatDate(new Date(frontmatter.pubDate))}
                    </time>
                </div>
                {
                    frontmatter.tags && (
                        <div class="flex flex-wrap gap-2 mt-4">
                            {frontmatter.tags.map((tag: string) => (
                                <span class="text-[0.75rem] tracking-[0.05em] text-muted bg-surface-2 border border-line py-[0.2rem] px-[0.6rem] rounded-sm">
                                    {tag}
                                </span>
                            ))}
                        </div>
                    )
                }
            </header>

            {
                frontmatter.image && (
                    <img
                        src={frontmatter.image.url}
                        alt={frontmatter.image.alt}
                        class="w-full rounded mb-8"
                    />
                )
            }

            <div class="prose">
                <slot />
            </div>
        </article>
    </div>
</Layout>

<style>
    .prose {
        color: var(--color-base);
        line-height: 1.8;
        font-size: 1.05rem;
    }

    .prose :global(h1),
    .prose :global(h2),
    .prose :global(h3),
    .prose :global(h4) {
        font-family: var(--font-serif);
        font-weight: 400;
        color: var(--color-base);
        margin-top: 2.5rem;
        margin-bottom: 0.75rem;
        line-height: 1.3;
    }

    .prose :global(h2) { font-size: 1.9rem; }
    .prose :global(h3) { font-size: 1.5rem; }
    .prose :global(h4) { font-size: 1.2rem; }

    .prose :global(p) { margin-bottom: 1.4rem; }

    .prose :global(a) {
        color: var(--color-accent);
        text-decoration: underline;
        text-underline-offset: 2px;
    }

    .prose :global(a:hover) { color: var(--color-base); }

    .prose :global(strong) {
        font-weight: 600;
        color: var(--color-base);
    }

    .prose :global(em) { font-style: italic; }

    .prose :global(ul),
    .prose :global(ol) {
        margin-bottom: 1.4rem;
        padding-left: 1.5rem;
    }

    .prose :global(ul) { list-style: disc; }
    .prose :global(ol) { list-style: decimal; }

    .prose :global(li) { margin-bottom: 0.4rem; }

    .prose :global(blockquote) {
        border-left: 3px solid var(--color-accent);
        padding-left: 1.25rem;
        margin: 1.5rem 0;
        color: var(--color-muted);
        font-style: italic;
    }

    .prose :global(code) {
        background: var(--color-surface-2);
        padding: 0.15rem 0.4rem;
        border-radius: 3px;
        font-size: 0.875em;
        color: var(--color-accent);
        font-family: monospace;
    }

    .prose :global(pre) {
        background: var(--color-surface-3);
        border: 1px solid var(--color-line);
        padding: 1.25rem;
        border-radius: 4px;
        overflow-x: auto;
        margin: 1.5rem 0;
    }

    .prose :global(pre code) {
        background: transparent;
        padding: 0;
        color: var(--color-base);
        font-size: 0.9rem;
    }

    .prose :global(hr) {
        border: none;
        border-top: 1px solid var(--color-line);
        margin: 2.5rem 0;
    }

    .prose :global(img) {
        border-radius: 4px;
        margin: 1.5rem 0;
        max-width: 100%;
    }

    .prose :global(table) {
        width: 100%;
        margin: 1.5rem 0;
        font-size: 0.95rem;
        border-collapse: collapse;
    }

    .prose :global(th) {
        background: var(--color-surface-2);
        padding: 0.6rem 1rem;
        text-align: left;
        font-weight: 600;
        color: var(--color-base);
        border-bottom: 1px solid var(--color-line);
    }

    .prose :global(td) {
        padding: 0.6rem 1rem;
        border-bottom: 1px solid var(--color-surface-2);
        color: var(--color-base);
    }
</style>
