---
import "../styles/global.css";
import "@fontsource/figtree";
import "@fontsource/petrona/400.css";
import Footer from "../components/Footer.astro";
import NavBar from "../components/NavBar.astro";

interface Props {
    hideHeader?: boolean;
}

const { hideHeader = false } = Astro.props;
const env = import.meta.env.PUBLIC_ENV as string;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>Aaron Ye</title>
        {
            env === "PROD" && (
                <script
                    defer
                    src="https://cloud.umami.is/script.js"
                    data-website-id="b38508b6-617a-47cf-9743-2bf62ecdca50"
                />
            )
        }
    </head>
    <body class="bg-surface text-base font-sans">
        <div class="flex flex-col justify-between min-h-screen relative z-10">
            <div>
                {
                    hideHeader ? (
                        <slot />
                    ) : (
                        <div class="min-h-screen bg-surface">
                            <nav class="max-w-6xl mx-auto flex items-center justify-between px-6 md:px-10 py-8">
                                <NavBar currentPath={Astro.url.pathname} />
                            </nav>
                            <div class="h-px bg-line" />
                            <div class="max-w-6xl mx-auto px-6 md:px-10 pb-12">
                                <slot />
                            </div>
                        </div>
                    )
                }
            </div>
            <Footer />
        </div>
    </body>
</html>
