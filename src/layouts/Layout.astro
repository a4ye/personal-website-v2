---
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import Spring from "../components/Spring.svelte";
import TitleSection from "../components/TitleSection.astro";

const env = import.meta.env.PUBLIC_ENV as string;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>Aaron Ye</title>
        <script is:inline>
            (function () {
                var theme = localStorage.getItem("theme");
                // Convert old theme names to new system
                if (theme === "latte") theme = "light";
                if (theme === "mocha") theme = "dark";
                if (theme !== "light" && theme !== "dark") theme = "light";
                document.documentElement.className = theme;
            })();
        </script>
        {
            env === "PROD" && (
                <script
                    defer
                    src="https://cloud.umami.is/script.js"
                    data-website-id="b38508b6-617a-47cf-9743-2bf62ecdca50"
                />
            )
        }
    </head>
    <body style="background: var(--bg-primary); color: var(--text-primary);" class="antialiased">
        <div class="flex flex-col justify-between min-h-screen">
            <div>
                <Spring client:only="svelte" />
                <!-- Navigation in constrained container -->
                <div class="px-8 sm:px-16 md:px-24 lg:px-32 xl:px-48 flex justify-center relative z-20">
                    <div class="w-full max-w-5xl">
                        <TitleSection />
                    </div>
                </div>
                <!-- Content slot: hero can be full-bleed, other sections constrained -->
                <slot />
            </div>
            <Footer />
        </div>
    </body>
</html>
