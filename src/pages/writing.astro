---
import Layout from "../layouts/Layout.astro";

const posts = Object.values(import.meta.glob("./writing/*.md", { eager: true })) as {
    frontmatter: {
        title: string;
        pubDate: string;
        description: string;
        tags?: string[];
    };
    url: string;
    rawContent?: () => string;
}[];

const sortedPosts = posts.sort((a, b) => {
    const dateA = new Date(a.frontmatter.pubDate);
    const dateB = new Date(b.frontmatter.pubDate);
    return dateB.getTime() - dateA.getTime();
});

const formatDate = (date: Date) => {
    return new Intl.DateTimeFormat("en-US", {
        year: "numeric",
        month: "long",
    })
        .format(date)
        .toUpperCase();
};

const getReadTime = (content: string) => {
    const words = content.split(/\s+/).length;
    const minutes = Math.ceil(words / 200);
    return `${minutes} MIN`;
};
---

<Layout>
    <div class="pt-20 pb-12 max-w-3xl mx-auto">
        <h1 class="font-serif text-5xl font-normal text-accent mb-3 pb-4">Writing</h1>
        <div class="flex flex-col">
            {
                sortedPosts.length === 0 ? (
                    <p class="text-muted">No posts yet. Check back soon!</p>
                ) : (
                    sortedPosts.map((post) => (
                        <a
                            href={post.url}
                            class="group no-underline block p-5 -mx-5 border-t border-line last:border-b hover:bg-surface-2 transition-colors duration-200"
                        >
                            <article>
                                <div class="text-[0.8rem] tracking-[0.1em] text-muted mb-2 flex items-center gap-2">
                                    <span>{formatDate(new Date(post.frontmatter.pubDate))}</span>
                                    <span class="text-line">·</span>
                                    <span>
                                        {post.rawContent ? getReadTime(post.rawContent()) : "3 MIN"}
                                    </span>
                                </div>
                                <h2 class="font-serif text-[1.65rem] font-normal text-base mb-2 transition-colors duration-200 group-hover:text-accent">
                                    {post.frontmatter.title}
                                </h2>
                                <p class="text-base leading-relaxed">{post.frontmatter.description}</p>
                            </article>
                        </a>
                    ))
                )
            }
        </div>
    </div>
</Layout>
