---
export const prerender = false;
import { getGuestbookEntriesPaginated, countGuestbookEntries } from "@/lib/sqlc/guestbook_sql";
import { db } from "@/lib/database";
import Layout from "../layouts/Layout.astro";
import loadingIcon from "../assets/icons/eos-icons--loading.svg";
import sanitizeHtml from "sanitize-html";

const ENTRIES_PER_PAGE = 10;

const url = new URL(Astro.request.url);
let page = parseInt(url.searchParams.get("page") || "1");

if (isNaN(page) || page < 1) {
    page = 1;
}

const countResult = await countGuestbookEntries(db);
const totalEntries = parseInt(countResult?.count || "0");
const totalPages = Math.ceil(totalEntries / ENTRIES_PER_PAGE);

if (totalPages > 0 && page > totalPages) {
    page = totalPages;
}

const guestbookEntries = await getGuestbookEntriesPaginated(db, {
    offset: ((page - 1) * ENTRIES_PER_PAGE).toString(),
});

function getPageNumbers(current: number, total: number): (number | "...")[] {
    if (total <= 3) {
        return Array.from({ length: total }, (_, i) => i + 1);
    }

    const pages: (number | "...")[] = [];

    if (current === 1) {
        pages.push(1, 2, 3);
        if (total > 4) pages.push("...");
        if (total > 3) pages.push(total);
    } else if (current === total) {
        if (total > 3) pages.push(1);
        if (total > 4) pages.push("...");
        pages.push(total - 2, total - 1, total);
    } else {
        if (current > 2) {
            pages.push(1);
            if (current > 3) pages.push("...");
        }
        pages.push(current - 1, current, current + 1);
        if (current < total - 1) {
            if (current < total - 2) pages.push("...");
            pages.push(total);
        }
    }

    return pages;
}

const miniPages = getPageNumbers(page, totalPages);

const formatMessage = (message: string) => {
    const sanitized = sanitizeHtml(message, { allowedTags: [], allowedAttributes: {} });
    return sanitized.replace(/\n/g, "<br>");
};

const pageBtnBase = "py-1 px-2 text-[0.9rem] no-underline rounded transition-colors duration-200";
const pageBtnDefault = `${pageBtnBase} text-muted hover:bg-surface-2 hover:text-base`;
const pageBtnActive = `${pageBtnBase} bg-accent text-surface font-medium hover:bg-accent hover:text-surface`;
const pageBtnDisabled = `${pageBtnBase} text-line pointer-events-none`;
---

<Layout>
    <div class="max-w-3xl mx-auto pt-20 pb-16">
        <h1 class="font-serif text-5xl font-normal text-accent mb-3">Guestbook</h1>
        <form id="guestbook-form" aria-label="Guestbook form">
            <div class="flex flex-col gap-4">
                <div class="flex flex-col gap-1.5">
                    <label class="text-sm tracking-[0.06em] text-muted" for="guestbookName">
                        Name <span class="text-muted">*</span>
                    </label>
                    <input
                        class="bg-transparent border border-line rounded-md px-3.5 py-2.5 text-base outline-none transition-colors duration-200 w-full placeholder:text-muted hover:border-muted focus:border-muted"
                        type="text"
                        id="guestbookName"
                        name="name"
                        placeholder="Your name"
                        required
                        aria-label="Name"
                    />
                </div>
                <div class="flex flex-col gap-1.5">
                    <label class="text-sm tracking-[0.06em] text-muted" for="guestbookMessage">
                        Message <span class="text-muted">*</span>
                    </label>
                    <textarea
                        class="bg-transparent border border-line rounded-md px-3.5 py-2.5 text-base outline-none transition-colors duration-200 w-full placeholder:text-muted hover:border-muted focus:border-muted resize-y min-h-24"
                        id="guestbookMessage"
                        name="message"
                        placeholder="Leave a message..."
                        required
                        aria-label="Message"></textarea>
                </div>
            </div>
            <div class="flex items-center justify-between mt-4 gap-4">
                <div class="flex-1">
                    <p id="form-error" class="text-[0.95rem] text-error m-0" aria-live="polite"></p>
                    <p id="form-success" class="text-[0.95rem] text-accent m-0" aria-live="polite"></p>
                </div>
                <button
                    id="submit-button"
                    class="bg-accent text-surface border-0 rounded-md px-5 py-2.5 text-[0.95rem] cursor-pointer flex items-center gap-2 transition-colors duration-200 whitespace-nowrap shrink-0 hover:bg-base disabled:opacity-60 disabled:cursor-not-allowed"
                    type="submit"
                    aria-label="Submit guestbook entry"
                >
                    <span id="submit-text">Submit</span>
                    <img
                        id="submit-loading"
                        class="hidden"
                        width="20"
                        height="20"
                        src={loadingIcon.src}
                        alt="Loading..."
                    />
                </button>
            </div>
        </form>

        <div class="mt-14">
            {
                totalEntries > 0 && (
                    <div
                        class="flex justify-between items-center pb-3"
                        data-pagination-container
                        aria-label="Pagination navigation"
                    >
                        <p
                            class="text-[0.875rem] text-muted tracking-[0.04em] m-0"
                            data-page-info
                            data-total-entries={totalEntries}
                            data-total-pages={totalPages}
                        >
                            Page {page} of {totalPages} · {totalEntries}{" "}
                            {totalEntries === 1 ? "message" : "messages"}
                        </p>
                        {totalPages > 1 && (
                            <div class="flex items-center gap-1" data-paginator aria-label="Page navigation">
                                <a
                                    href={page > 1 ? `?page=${page - 1}` : undefined}
                                    class={page === 1 ? pageBtnDisabled : pageBtnDefault}
                                    aria-disabled={page === 1}
                                    aria-label="Previous page"
                                >
                                    ←
                                </a>
                                {miniPages.map((p) =>
                                    p === "..." ? (
                                        <span class="text-[0.9rem] text-line px-1" aria-hidden="true">
                                            …
                                        </span>
                                    ) : (
                                        <a
                                            href={`?page=${p}`}
                                            class={p === page ? pageBtnActive : pageBtnDefault}
                                            aria-current={p === page ? "page" : undefined}
                                        >
                                            {p}
                                        </a>
                                    ),
                                )}
                                <a
                                    href={page < totalPages ? `?page=${page + 1}` : undefined}
                                    class={page === totalPages ? pageBtnDisabled : pageBtnDefault}
                                    aria-disabled={page === totalPages}
                                    aria-label="Next page"
                                >
                                    →
                                </a>
                            </div>
                        )}
                    </div>
                )
            }

            <div id="entries-container" aria-label="Guestbook entries">
                {
                    guestbookEntries.length === 0 ? (
                        <p class="text-muted py-8 border-t border-line m-0" data-empty-state>
                            No messages yet. Be the first to leave one!
                        </p>
                    ) : (
                        guestbookEntries.map((entry) => (
                            <div class="py-6 border-t border-line last:border-b last:border-line" aria-label="Guestbook entry">
                                <div class="flex justify-between items-baseline mb-[0.625rem] gap-4">
                                    <span class="font-serif text-[1.2rem] text-accent">{entry.name}</span>
                                    <span
                                        class="text-[0.8rem] tracking-[0.08em] text-muted whitespace-nowrap guestbook-date"
                                        data-iso={entry.createdAt!}
                                        aria-label="Entry date"
                                    />
                                </div>
                                <p class="text-base leading-[1.7] m-0" set:html={formatMessage(entry.message)} />
                            </div>
                        ))
                    )
                }
            </div>

            {
                totalEntries > 0 && totalPages > 1 && (
                    <div
                        class="flex justify-between items-center pt-3 pb-0 border-t border-line"
                        data-pagination-container
                        aria-label="Pagination navigation"
                    >
                        <p class="text-[0.875rem] text-muted tracking-[0.04em] m-0" data-page-info>
                            Page {page} of {totalPages} · {totalEntries}{" "}
                            {totalEntries === 1 ? "message" : "messages"}
                        </p>
                        <div class="flex items-center gap-1" data-paginator aria-label="Page navigation">
                            <a
                                href={page > 1 ? `?page=${page - 1}` : undefined}
                                class={page === 1 ? pageBtnDisabled : pageBtnDefault}
                                aria-disabled={page === 1}
                            >
                                ←
                            </a>
                            {miniPages.map((p) =>
                                p === "..." ? (
                                    <span class="text-[0.9rem] text-line px-1" aria-hidden="true">
                                        …
                                    </span>
                                ) : (
                                    <a
                                        href={`?page=${p}`}
                                        class={p === page ? pageBtnActive : pageBtnDefault}
                                        aria-current={p === page ? "page" : undefined}
                                    >
                                        {p}
                                    </a>
                                ),
                            )}
                            <a
                                href={page < totalPages ? `?page=${page + 1}` : undefined}
                                class={page === totalPages ? pageBtnDisabled : pageBtnDefault}
                                aria-disabled={page === totalPages}
                            >
                                →
                            </a>
                        </div>
                    </div>
                )
            }
        </div>
    </div>
</Layout>

<script>
    import { actions, isInputError } from "astro:actions";

    // Tailwind class strings for JS-generated DOM (must be full strings for content scanning)
    const BTN_BASE = "py-1 px-2 text-[0.9rem] no-underline rounded transition-colors duration-200";
    const BTN_DEFAULT = `${BTN_BASE} text-muted hover:bg-surface-2 hover:text-base`;
    const BTN_ACTIVE = `${BTN_BASE} bg-accent text-surface font-medium hover:bg-accent hover:text-surface`;
    const BTN_DISABLED = `${BTN_BASE} text-line pointer-events-none`;

    function escapeHtml(text: string): string {
        const div = document.createElement("div");
        div.textContent = text;
        return div.innerHTML;
    }

    const form = document.getElementById("guestbook-form") as HTMLFormElement;
    const formError = document.getElementById("form-error") as HTMLParagraphElement;
    const formSuccess = document.getElementById("form-success") as HTMLParagraphElement;
    const entriesContainer = document.getElementById("entries-container") as HTMLDivElement;
    const submitButton = document.getElementById("submit-button") as HTMLButtonElement;
    const submitText = document.getElementById("submit-text") as HTMLSpanElement;
    const submitLoading = document.getElementById("submit-loading") as unknown as SVGElement;

    let currentPage = parseInt(new URL(window.location.href).searchParams.get("page") || "1");
    let totalEntries = parseInt(
        document.querySelector("[data-total-entries]")?.getAttribute("data-total-entries") || "0",
    );
    let totalPages = parseInt(
        document.querySelector("[data-total-pages]")?.getAttribute("data-total-pages") || "1",
    );
    const ENTRIES_PER_PAGE = 10;

    function sanitize(text: string, preserveNewlines = false): string {
        let sanitized = escapeHtml(text);
        if (preserveNewlines) sanitized = sanitized.replace(/\n/g, "<br>");
        return sanitized;
    }

    function setLoading(loading: boolean) {
        submitButton.disabled = loading;
        submitText.classList.toggle("hidden", loading);
        submitLoading.classList.toggle("hidden", !loading);
    }

    function getPageNumbers(current: number, total: number): (number | "...")[] {
        if (total <= 3) return Array.from({ length: total }, (_, i) => i + 1);
        const pages: (number | "...")[] = [];
        if (current === 1) {
            pages.push(1, 2, 3);
            if (total > 4) pages.push("...");
            if (total > 3) pages.push(total);
        } else if (current === total) {
            if (total > 3) pages.push(1);
            if (total > 4) pages.push("...");
            pages.push(total - 2, total - 1, total);
        } else {
            if (current > 2) {
                pages.push(1);
                if (current > 3) pages.push("...");
            }
            pages.push(current - 1, current, current + 1);
            if (current < total - 1) {
                if (current < total - 2) pages.push("...");
                pages.push(total);
            }
        }
        return pages;
    }

    function formatDateLocal(iso: string): string {
        const d = new Date(iso);
        return d.toLocaleDateString(undefined, {
            year: "numeric",
            month: "long",
            day: "numeric",
        });
    }

    function formatAllDatesToLocal() {
        document.querySelectorAll(".guestbook-date").forEach((el) => {
            const iso = el.getAttribute("data-iso");
            if (iso) el.textContent = formatDateLocal(iso);
        });
    }

    formatAllDatesToLocal();

    const observer = new MutationObserver(() => formatAllDatesToLocal());
    observer.observe(entriesContainer, { childList: true });

    function updatePagination() {
        const existingContainers = document.querySelectorAll("[data-pagination-container]");

        if (existingContainers.length === 0 && totalEntries > 0) {
            const topContainer = document.createElement("div");
            topContainer.className = "flex justify-between items-center pb-3";
            topContainer.setAttribute("data-pagination-container", "");
            topContainer.innerHTML = `
                <p class="text-[0.875rem] text-muted tracking-[0.04em] m-0" data-page-info data-total-entries="${totalEntries}" data-total-pages="${totalPages}">
                    Page ${currentPage} of ${totalPages} · ${totalEntries} ${totalEntries === 1 ? "message" : "messages"}
                </p>
                <div class="flex items-center gap-1" data-paginator></div>
            `;
            entriesContainer.before(topContainer);
            updatePaginatorElements(
                document.querySelectorAll("[data-paginator]") as NodeListOf<HTMLDivElement>,
            );
            return;
        }

        document.querySelectorAll("[data-page-info]").forEach((el) => {
            el.textContent = `Page ${currentPage} of ${totalPages} · ${totalEntries} ${totalEntries === 1 ? "message" : "messages"}`;
        });
        updatePaginatorElements(
            document.querySelectorAll("[data-paginator]") as NodeListOf<HTMLDivElement>,
        );
    }

    function updatePaginatorElements(elements: NodeListOf<HTMLDivElement>) {
        const miniPages = getPageNumbers(currentPage, totalPages);
        elements.forEach((paginator) => {
            if (totalPages <= 1) {
                paginator.innerHTML = "";
                return;
            }
            let html = `<a href="${currentPage > 1 ? `?page=${currentPage - 1}` : "javascript:void(0)"}" class="${currentPage === 1 ? BTN_DISABLED : BTN_DEFAULT}" ${currentPage === 1 ? 'aria-disabled="true"' : ""}>←</a>`;
            miniPages.forEach((p) => {
                if (p === "...") {
                    html += `<span class="text-[0.9rem] text-line px-1">…</span>`;
                } else {
                    html += `<a href="?page=${p}" class="${p === currentPage ? BTN_ACTIVE : BTN_DEFAULT}">${p}</a>`;
                }
            });
            html += `<a href="${currentPage < totalPages ? `?page=${currentPage + 1}` : "javascript:void(0)"}" class="${currentPage === totalPages ? BTN_DISABLED : BTN_DEFAULT}" ${currentPage === totalPages ? 'aria-disabled="true"' : ""}>→</a>`;
            paginator.innerHTML = html;
        });
    }

    form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const formData = new FormData(form);

        setLoading(true);
        const result = await actions.submitGuestbookEntry(formData);
        setLoading(false);

        if (isInputError(result.error)) {
            formSuccess.textContent = "";
            if (result.error.fields.name) {
                formError.textContent = "Name must be between 1 and 32 characters.";
            } else if (result.error.fields.message) {
                formError.textContent = "Message must be between 1 and 1024 characters.";
            }
            return;
        }

        if (result.error) {
            formSuccess.textContent = "";
            formError.textContent = result.error.message || "An unknown error occurred.";
            return;
        }

        if (!result.data) {
            formSuccess.textContent = "";
            formError.textContent = "An unknown error occurred.";
            return;
        }

        formError.textContent = "";
        formSuccess.textContent = "Message submitted!";
        form.reset();

        totalEntries++;
        totalPages = Math.ceil(totalEntries / ENTRIES_PER_PAGE);
        currentPage = 1;
        updatePagination();

        if (
            (currentPage === 1 && window.location.search === "") ||
            window.location.search === "?page=1"
        ) {
            const emptyState = entriesContainer.querySelector("[data-empty-state]");
            if (emptyState) emptyState.remove();

            function decodeEntities(encoded: string): string {
                const textarea = document.createElement("textarea");
                textarea.innerHTML = encoded || "";
                return textarea.value;
            }

            function createMessageEl(serverMessage: string): HTMLParagraphElement {
                const p = document.createElement("p");
                p.className = "text-base leading-[1.7] m-0";
                const parts = serverMessage.split("\n");
                parts.forEach((part: string, idx: number) => {
                    p.appendChild(document.createTextNode(decodeEntities(part)));
                    if (idx < parts.length - 1) p.appendChild(document.createElement("br"));
                });
                return p;
            }

            const entryEl = document.createElement("div");
            entryEl.className = "py-6 border-t border-line last:border-b last:border-line";

            const header = document.createElement("div");
            header.className = "flex justify-between items-baseline mb-[0.625rem] gap-4";

            const nameEl = document.createElement("span");
            nameEl.className = "font-serif text-[1.2rem] text-accent";
            nameEl.textContent = decodeEntities(result.data.name || "");

            const dateEl = document.createElement("span");
            dateEl.className = "text-[0.8rem] tracking-[0.08em] text-muted whitespace-nowrap guestbook-date";
            dateEl.setAttribute(
                "data-iso",
                result.data.createdAt ? String(result.data.createdAt) : "",
            );

            header.appendChild(nameEl);
            header.appendChild(dateEl);
            entryEl.appendChild(header);
            entryEl.appendChild(createMessageEl(result.data.message || ""));
            entriesContainer.prepend(entryEl);

            const entries = entriesContainer.children;
            if (entries.length > ENTRIES_PER_PAGE) entries[entries.length - 1].remove();
        } else {
            try {
                const response = await fetch("/api/guestbook-entries?page=1");
                const data = await response.json();
                if (data.entries) {
                    entriesContainer.innerHTML = data.entries
                        .map(
                            (entry: any) => `
                        <div class="py-6 border-t border-line last:border-b last:border-line">
                            <div class="flex justify-between items-baseline mb-[0.625rem] gap-4">
                                <span class="font-serif text-[1.2rem] text-accent">${sanitize(entry.name)}</span>
                                <span class="text-[0.8rem] tracking-[0.08em] text-muted whitespace-nowrap guestbook-date" data-iso="${entry.createdAt}"></span>
                            </div>
                            <p class="text-base leading-[1.7] m-0">${sanitize(entry.message, true)}</p>
                        </div>
                    `,
                        )
                        .join("");
                    window.history.pushState({}, "", "/guestbook");
                }
            } catch (error) {
                console.error("Failed to fetch page 1 entries:", error);
            }
        }

        setTimeout(() => {
            formSuccess.textContent = "";
        }, 3000);
    });
</script>
