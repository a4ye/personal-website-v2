---
export const prerender = false;
import { getGuestbookEntriesPaginated, countGuestbookEntries } from "@/lib/sqlc/guestbook_sql";
import { db } from "@/lib/database";
import Layout from "../layouts/Layout.astro";
import loadingIcon from "../assets/icons/eos-icons--loading.svg";
import sanitizeHtml from "sanitize-html";

const ENTRIES_PER_PAGE = 10;

const url = new URL(Astro.request.url);
let page = parseInt(url.searchParams.get("page") || "1");

if (isNaN(page) || page < 1) {
    page = 1;
}

// Get total count first to clamp page
const countResult = await countGuestbookEntries(db);
const totalEntries = parseInt(countResult?.count || "0");
const totalPages = Math.ceil(totalEntries / ENTRIES_PER_PAGE);

// Clamp page to valid range before fetching
if (totalPages > 0 && page > totalPages) {
    page = totalPages;
}

const guestbookEntries = await getGuestbookEntriesPaginated(db, {
    offset: ((page - 1) * ENTRIES_PER_PAGE).toString(),
});

// Generate page numbers for pagination
function getPageNumbers(current: number, total: number): (number | "...")[] {
    if (total <= 3) {
        return Array.from({ length: total }, (_, i) => i + 1);
    }

    const pages: (number | "...")[] = [];

    if (current === 1) {
        // First page: show 1, 2, 3, ..., last
        pages.push(1, 2, 3);
        if (total > 4) pages.push("...");
        if (total > 3) pages.push(total);
    } else if (current === total) {
        // Last page: show first, ..., last-2, last-1, last
        if (total > 3) pages.push(1);
        if (total > 4) pages.push("...");
        pages.push(total - 2, total - 1, total);
    } else {
        // Middle: show first, ..., prev, current, next, ..., last
        if (current > 2) {
            pages.push(1);
            if (current > 3) pages.push("...");
        }
        pages.push(current - 1, current, current + 1);
        if (current < total - 1) {
            if (current < total - 2) pages.push("...");
            pages.push(total);
        }
    }

    return pages;
}

const miniPages = getPageNumbers(page, totalPages);

const locale = new Intl.Locale("en-CA", {
    hourCycle: "h23",
});

const dateFormat = new Intl.DateTimeFormat(locale, {
    year: "numeric",
    month: "long",
    day: "numeric",
    hour: "numeric",
    minute: "numeric",
    second: "numeric",
    hour12: false,
});

const formatDate = (date: Date | string) => {
    // Accepts Date or string, parses as local time
    const d = typeof date === "string" ? new Date(date) : date;
    return dateFormat.format(d);
};

// Sanitize HTML and convert newlines to <br> for safe rendering
const formatMessage = (message: string) => {
    const sanitized = sanitizeHtml(message, { allowedTags: [], allowedAttributes: {} });
    return sanitized.replace(/\n/g, "<br>");
};
---

<Layout>
    <div class="px-8 sm:px-16 md:px-24 lg:px-32 xl:px-48 flex justify-center">
    <div class="w-full max-w-5xl">
    <!-- Page Header -->
    <section class="pb-16 sm:pb-20 animate-fadeInUp opacity-0">
        <h1 class="text-5xl sm:text-6xl md:text-7xl font-display font-bold pb-6" style="color: var(--text-primary);">
            Guestbook
        </h1>
        <p class="text-lg sm:text-xl leading-relaxed max-w-2xl" style="color: var(--text-secondary); font-weight: 300;">
            Leave a message and say hello. I read and appreciate every entry.
        </p>
    </section>

    <!-- Form -->
    <form id="guestbook-form" class="pb-20 sm:pb-24 animate-fadeInUp opacity-0 stagger-1 max-w-2xl" aria-label="Guestbook form">
        <div class="flex flex-col gap-3 pb-6">
            <label for="guestbookName" class="font-semibold text-base" style="color: var(--text-primary);">
                Name <span style="color: var(--accent-red);">*</span>
            </label>
            <input
                class="border-2 h-12 px-4 text-base rounded-lg transition-all duration-300 focus:outline-none"
                style="border-color: var(--border); background: var(--bg-secondary); color: var(--text-primary);"
                type="text"
                id="guestbookName"
                name="name"
                placeholder="Your Name"
                required
                aria-label="Name"
                onfocus="this.style.borderColor='var(--accent-blue)'"
                onblur="this.style.borderColor='var(--border)'"
            />
        </div>
        <div class="flex flex-col gap-3 pb-8">
            <label for="guestbookMessage" class="font-semibold text-base" style="color: var(--text-primary);">
                Message <span style="color: var(--accent-red);">*</span>
            </label>
            <textarea
                class="border-2 p-4 text-base rounded-lg transition-all duration-300 focus:outline-none min-h-40"
                style="border-color: var(--border); background: var(--bg-secondary); color: var(--text-primary);"
                id="guestbookMessage"
                name="message"
                placeholder="Leave a message..."
                required
                aria-label="Message"
                onfocus="this.style.borderColor='var(--accent-blue)'"
                onblur="this.style.borderColor='var(--border)'"
            ></textarea>
        </div>
        <button
            id="submit-button"
            class="font-semibold text-base transition-all duration-300 cursor-pointer px-8 py-3 flex items-center justify-center gap-2 rounded-lg text-white hover:shadow-lg hover:-translate-y-1"
            style="background: linear-gradient(135deg, var(--accent-purple), var(--accent-pink));"
            type="submit"
            aria-label="Submit guestbook entry"
        >
            <span id="submit-text">Submit</span>
            <img
                id="submit-loading"
                class="hidden"
                width="20"
                height="20"
                src={loadingIcon.src}
                alt="Loading..."
                aria-label="Loading indicator"
            />
        </button>
        <div class="flex flex-row gap-4 pt-4">
            <p
                id="form-error"
                class="h-5 text-sm font-medium"
                style="color: var(--accent-red);"
                aria-live="polite"
                aria-label="Form error message"
            >
            </p>
            <p
                id="form-success"
                class="h-5 text-sm font-medium"
                style="color: var(--accent-blue);"
                aria-live="polite"
                aria-label="Form success message"
            >
            </p>
        </div>
    </form>

    <!-- Page info and pagination -->
    {
        totalEntries > 0 && (
            <div
                class="flex justify-between items-center pb-10"
                data-pagination-container
                aria-label="Pagination navigation"
            >
                <p
                    class="text-sm"
                    style="color: var(--text-tertiary);"
                    data-page-info
                    data-total-entries={totalEntries}
                    data-total-pages={totalPages}
                    aria-label="Page and message count"
                >
                    Page {page} of {totalPages} ({totalEntries}
                    {totalEntries === 1 ? "message" : "messages"})
                </p>
                {totalPages > 0 && (
                    <div
                        class="flex items-center gap-1"
                        data-paginator
                        aria-label="Page navigation"
                    >
                        <a
                            href={page > 1 ? `?page=${page - 1}` : undefined}
                            class={`px-3 py-2 text-sm rounded-md transition-all duration-300 ${page === 1 ? "cursor-not-allowed opacity-30" : "hover:shadow-md"}`}
                            style={page === 1 ? "color: var(--text-tertiary);" : "color: var(--text-primary); background: var(--bg-secondary);"}
                            aria-disabled={page === 1}
                            aria-label="Previous page"
                        >
                            ←
                        </a>
                        {miniPages.map((p) =>
                            p === "..." ? (
                                <span class="text-sm px-2" style="color: var(--text-tertiary);" aria-hidden="true">
                                    ...
                                </span>
                            ) : (
                                <a
                                    href={`?page=${p}`}
                                    class={`px-3 py-2 text-sm rounded-md transition-all duration-300 ${p === page ? "font-semibold text-white" : "hover:shadow-md"}`}
                                    style={p === page ? "background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple)); color: white;" : "color: var(--text-primary); background: var(--bg-secondary);"}
                                    aria-current={p === page ? "page" : undefined}
                                    aria-label={`Go to page ${p}`}
                                >
                                    {p}
                                </a>
                            ),
                        )}
                        <a
                            href={page < totalPages ? `?page=${page + 1}` : undefined}
                            class={`px-3 py-2 text-sm rounded-md transition-all duration-300 ${page === totalPages ? "cursor-not-allowed opacity-30" : "hover:shadow-md"}`}
                            style={page === totalPages ? "color: var(--text-tertiary);" : "color: var(--text-primary); background: var(--bg-secondary);"}
                            aria-disabled={page === totalPages}
                            aria-label="Next page"
                        >
                            →
                        </a>
                    </div>
                )}
            </div>
        )
    }

    <div
        id="entries-container"
        class="flex flex-col gap-4 pb-40"
        aria-label="Guestbook entries list"
    >
        {
            guestbookEntries.length === 0 ? (
                <div
                    class="text-center py-32"
                    style="color: var(--text-secondary);"
                    data-empty-state
                    aria-label="No messages state"
                >
                    <p class="text-2xl font-display font-bold" style="color: var(--text-primary);">No messages yet.</p>
                    <p class="text-base pt-2">Be the first to leave a message!</p>
                </div>
            ) : (
                guestbookEntries.map((entry, index) => (
                    <div
                        class="p-6 sm:p-8 rounded-lg border animate-fadeInUp opacity-0 stagger-{index % 6 + 1} transition-all hover:shadow-md"
                        style="border-color: var(--border); background: var(--bg-secondary);"
                        aria-label="Guestbook entry"
                    >
                        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-2 pb-4">
                            <h3 class="font-display text-lg sm:text-xl font-bold" style="color: var(--text-primary);" aria-label="Entry author">
                                {entry.name}
                            </h3>
                            <span
                                class="guestbook-date text-xs sm:text-sm"
                                style="color: var(--text-tertiary);"
                                data-iso={entry.createdAt!}
                                aria-label="Entry date"
                            />
                        </div>
                        <p
                            class="text-base leading-relaxed"
                            style="color: var(--text-secondary);"
                            set:html={formatMessage(entry.message)}
                            aria-label="Entry message"
                        />
                    </div>
                ))
            )
        }
    </div>

    <!-- Bottom pagination -->
    {
        totalEntries > 0 && (
            <div
                class="flex justify-between items-center border-t pt-10 pb-16"
                style="border-color: var(--border);"
                data-pagination-container
                aria-label="Pagination navigation"
            >
                <p class="text-sm" style="color: var(--text-tertiary);" data-page-info aria-label="Page and message count">
                    Page {page} of {totalPages} ({totalEntries}
                    {totalEntries === 1 ? "message" : "messages"})
                </p>
                {totalPages > 0 && (
                    <div
                        class="flex items-center gap-1"
                        data-paginator
                        aria-label="Page navigation"
                    >
                        <a
                            href={page > 1 ? `?page=${page - 1}` : undefined}
                            class={`px-3 py-2 text-sm rounded-md transition-all duration-300 ${page === 1 ? "cursor-not-allowed opacity-30" : "hover:shadow-md"}`}
                            style={page === 1 ? "color: var(--text-tertiary);" : "color: var(--text-primary); background: var(--bg-secondary);"}
                            aria-disabled={page === 1}
                            aria-label="Previous page"
                        >
                            ←
                        </a>
                        {miniPages.map((p) =>
                            p === "..." ? (
                                <span class="text-sm px-2" style="color: var(--text-tertiary);" aria-hidden="true">
                                    ...
                                </span>
                            ) : (
                                <a
                                    href={`?page=${p}`}
                                    class={`px-3 py-2 text-sm rounded-md transition-all duration-300 ${p === page ? "font-semibold text-white" : "hover:shadow-md"}`}
                                    style={p === page ? "background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple)); color: white;" : "color: var(--text-primary); background: var(--bg-secondary);"}
                                    aria-current={p === page ? "page" : undefined}
                                    aria-label={`Go to page ${p}`}
                                >
                                    {p}
                                </a>
                            ),
                        )}
                        <a
                            href={page < totalPages ? `?page=${page + 1}` : undefined}
                            class={`px-3 py-2 text-sm rounded-md transition-all duration-300 ${page === totalPages ? "cursor-not-allowed opacity-30" : "hover:shadow-md"}`}
                            style={page === totalPages ? "color: var(--text-tertiary);" : "color: var(--text-primary); background: var(--bg-secondary);"}
                            aria-disabled={page === totalPages}
                            aria-label="Next page"
                        >
                            →
                        </a>
                    </div>
                )}
            </div>
        )
    }
    </div>
    </div>
</Layout>

<script>
    import { actions, isInputError } from "astro:actions";

    // Simple HTML escape function for client-side sanitization
    function escapeHtml(text: string): string {
        const div = document.createElement("div");
        div.textContent = text;
        return div.innerHTML;
    }

    const form = document.getElementById("guestbook-form") as HTMLFormElement;
    const formError = document.getElementById("form-error") as HTMLParagraphElement;
    const formSuccess = document.getElementById("form-success") as HTMLParagraphElement;
    const entriesContainer = document.getElementById("entries-container") as HTMLDivElement;
    const submitButton = document.getElementById("submit-button") as HTMLButtonElement;
    const submitText = document.getElementById("submit-text") as HTMLSpanElement;
    const submitLoading = document.getElementById("submit-loading") as unknown as SVGElement;

    let currentPage = parseInt(new URL(window.location.href).searchParams.get("page") || "1");
    let totalEntries = parseInt(
        document.querySelector("[data-total-entries]")?.getAttribute("data-total-entries") || "0",
    );
    let totalPages = parseInt(
        document.querySelector("[data-total-pages]")?.getAttribute("data-total-pages") || "1",
    );
    const ENTRIES_PER_PAGE = 10;

    // Sanitize HTML and optionally convert newlines to <br>
    function sanitize(text: string, preserveNewlines = false): string {
        let sanitized = escapeHtml(text);

        if (preserveNewlines) {
            sanitized = sanitized.replace(/\n/g, "<br>");
        }

        return sanitized;
    }

    function setLoading(loading: boolean) {
        submitButton.disabled = loading;
        submitText.classList.toggle("hidden", loading);
        submitLoading.classList.toggle("hidden", !loading);
    }

    function getPageNumbers(current: number, total: number): (number | "...")[] {
        if (total <= 3) {
            return Array.from({ length: total }, (_, i) => i + 1);
        }

        const pages: (number | "...")[] = [];

        if (current === 1) {
            pages.push(1, 2, 3);
            if (total > 4) pages.push("...");
            if (total > 3) pages.push(total);
        } else if (current === total) {
            if (total > 3) pages.push(1);
            if (total > 4) pages.push("...");
            pages.push(total - 2, total - 1, total);
        } else {
            if (current > 2) {
                pages.push(1);
                if (current > 3) pages.push("...");
            }
            pages.push(current - 1, current, current + 1);
            if (current < total - 1) {
                if (current < total - 2) pages.push("...");
                pages.push(total);
            }
        }

        return pages;
    }

    function updatePagination() {
        // Check if pagination containers exist in the DOM (not from initial query which may be stale)
        const existingContainers = document.querySelectorAll("[data-pagination-container]");

        // If there are no pagination containers but we now have entries, create them
        if (existingContainers.length === 0 && totalEntries > 0) {
            // Create top pagination container
            const topContainer = document.createElement("div");
            topContainer.className = "flex justify-between items-center pb-10";
            topContainer.setAttribute("data-pagination-container", "");
            topContainer.innerHTML = `
                <p class="text-sm" style="color: var(--text-tertiary);" data-page-info data-total-entries="${totalEntries}" data-total-pages="${totalPages}">
                    Page ${currentPage} of ${totalPages} (${totalEntries} ${totalEntries === 1 ? "message" : "messages"})
                </p>
                <div class="flex items-center gap-1" data-paginator></div>
            `;
            entriesContainer.before(topContainer);

            // Create bottom pagination container
            const bottomContainer = document.createElement("div");
            bottomContainer.className = "flex justify-between items-center border-t pt-10 pb-16";
            bottomContainer.style.borderColor = "var(--border)";
            bottomContainer.setAttribute("data-pagination-container", "");
            bottomContainer.innerHTML = `
                <p class="text-sm" style="color: var(--text-tertiary);" data-page-info>
                    Page ${currentPage} of ${totalPages} (${totalEntries} ${totalEntries === 1 ? "message" : "messages"})
                </p>
                <div class="flex items-center gap-1" data-paginator></div>
            `;
            entriesContainer.after(bottomContainer);

            // Re-query the elements and update paginators
            const newPaginatorElements = document.querySelectorAll(
                "[data-paginator]",
            ) as NodeListOf<HTMLDivElement>;
            updatePaginatorElements(newPaginatorElements);
            return;
        }

        // Re-query page info and paginator elements to get current state
        const currentPageInfoElements = document.querySelectorAll(
            "[data-page-info]",
        ) as NodeListOf<HTMLParagraphElement>;
        const currentPaginatorElements = document.querySelectorAll(
            "[data-paginator]",
        ) as NodeListOf<HTMLDivElement>;

        // Update page info text
        currentPageInfoElements.forEach((el) => {
            el.textContent = `Page ${currentPage} of ${totalPages} (${totalEntries} ${totalEntries === 1 ? "message" : "messages"})`;
        });

        // Update paginators
        updatePaginatorElements(currentPaginatorElements);
    }

    function updatePaginatorElements(elements: NodeListOf<HTMLDivElement>) {
        const miniPages = getPageNumbers(currentPage, totalPages);

        elements.forEach((paginator) => {
            if (totalPages === 0) {
                paginator.innerHTML = "";
                return;
            }

            let html = `
                <a href="${currentPage > 1 ? `?page=${currentPage - 1}` : "javascript:void(0)"}"
                   class="px-3 py-2 text-sm rounded-md transition-all duration-300 ${currentPage === 1 ? "cursor-not-allowed opacity-30" : "hover:shadow-md"}"
                   style="${currentPage === 1 ? "color: var(--text-tertiary);" : "color: var(--text-primary); background: var(--bg-secondary);"}"
                   ${currentPage === 1 ? 'aria-disabled="true"' : ""}>
                    ←
                </a>
            `;

            miniPages.forEach((p) => {
                if (p === "...") {
                    html += `<span class="text-sm px-2" style="color: var(--text-tertiary);">...</span>`;
                } else {
                    html += `
                        <a href="?page=${p}"
                           class="px-3 py-2 text-sm rounded-md transition-all duration-300 ${p === currentPage ? "font-semibold text-white" : "hover:shadow-md"}"
                           style="${p === currentPage ? "background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple)); color: white;" : "color: var(--text-primary); background: var(--bg-secondary);"}">
                            ${p}
                        </a>
                    `;
                }
            });

            html += `
                <a href="${currentPage < totalPages ? `?page=${currentPage + 1}` : "javascript:void(0)"}"
                   class="px-3 py-2 text-sm rounded-md transition-all duration-300 ${currentPage === totalPages ? "cursor-not-allowed opacity-30" : "hover:shadow-md"}"
                   style="${currentPage === totalPages ? "color: var(--text-tertiary);" : "color: var(--text-primary); background: var(--bg-secondary);"}"
                   ${currentPage === totalPages ? 'aria-disabled="true"' : ""}>
                    →
                </a>
            `;

            paginator.innerHTML = html;
        });
    }

    // Format all .guestbook-date elements to local time zone on client
    function formatAllDatesToLocal() {
        const dateElements = document.querySelectorAll(".guestbook-date");
        dateElements.forEach((el) => {
            const iso = el.getAttribute("data-iso");
            if (!iso) return;
            const d = new Date(iso);
            el.textContent = d.toLocaleString(undefined, {
                year: "numeric",
                month: "long",
                day: "numeric",
                hour: "numeric",
                minute: "numeric",
                second: "numeric",
                hour12: false,
            });
        });
    }

    // Run on load
    formatAllDatesToLocal();

    // Also run after a new entry is added
    function observeNewEntries() {
        const observer = new MutationObserver((mutations) => {
            for (const mutation of mutations) {
                if (mutation.type === "childList" && mutation.addedNodes.length > 0) {
                    formatAllDatesToLocal();
                }
            }
        });
        observer.observe(entriesContainer, { childList: true });
    }
    observeNewEntries();

    form.addEventListener("submit", async (e) => {
        e.preventDefault();

        const formData = new FormData(form);

        setLoading(true);
        const result = await actions.submitGuestbookEntry(formData);
        setLoading(false);

        if (isInputError(result.error)) {
            formSuccess.textContent = "";
            if (result.error.fields.name) {
                formError.textContent = "Name must between 1 and 32 characters.";
                return;
            } else if (result.error.fields.message) {
                formError.textContent = "Message must be between 1 and 1024 characters.";
                return;
            }
            return;
        }

        if (result.error) {
            formSuccess.textContent = "";
            formError.textContent = result.error.message || "An unknown error occurred :(";
            return;
        }

        if (!result.data) {
            formSuccess.textContent = "";
            formError.textContent = "An unknown error occurred :(";
            return;
        }

        formError.textContent = "";
        formSuccess.textContent = "Successfully submitted!";
        form.reset();

        // Update pagination counts
        totalEntries++;
        totalPages = Math.ceil(totalEntries / ENTRIES_PER_PAGE);
        currentPage = 1; // Go back to page 1
        updatePagination();

        // If we were on page 1, just prepend the new entry and remove the last if needed
        // Otherwise, fetch page 1 entries from the server
        if (
            (currentPage === 1 && window.location.search === "") ||
            window.location.search === "?page=1"
        ) {
            // Add new entry to the top of the list
            const emptyState = entriesContainer.querySelector("[data-empty-state]");
            if (emptyState) {
                emptyState.remove();
            }

            // Helper to decode HTML entities (server-side escaped) safely
            function decodeEntities(encodedString: string): string {
                const textarea = document.createElement("textarea");
                textarea.innerHTML = encodedString || "";
                return textarea.value;
            }

            // Helper to create a paragraph element with preserved newlines
            function createMessageParagraph(serverMessage: string): HTMLParagraphElement {
                const p = document.createElement("p");
                p.className = "pt-4";

                if (!serverMessage) return p;

                const parts = serverMessage.split("\n");
                parts.forEach((part: string, idx: number) => {
                    const decoded = decodeEntities(part);
                    p.appendChild(document.createTextNode(decoded));
                    if (idx < parts.length - 1) p.appendChild(document.createElement("br"));
                });

                return p;
            }

            const entryWrapper = document.createElement("div");
            entryWrapper.className = "p-6 sm:p-8 rounded-lg border transition-all hover:shadow-md";
            entryWrapper.style.borderColor = "var(--border)";
            entryWrapper.style.background = "var(--bg-secondary)";

            const header = document.createElement("div");
            header.className = "flex flex-col sm:flex-row sm:justify-between sm:items-start gap-2 pb-4";

            const nameEl = document.createElement("h3");
            nameEl.className = "font-display text-lg sm:text-xl font-bold";
            nameEl.style.color = "var(--text-primary)";
            nameEl.textContent = decodeEntities(result.data.name || "");

            const dateEl = document.createElement("span");
            dateEl.className = "guestbook-date text-xs sm:text-sm";
            dateEl.style.color = "var(--text-tertiary)";
            const dateValue = result.data.createdAt ? String(result.data.createdAt) : "";
            dateEl.setAttribute("data-iso", dateValue);
            // Will be formatted by formatAllDatesToLocal()

            header.appendChild(nameEl);
            header.appendChild(dateEl);

            const messageEl = createMessageParagraph(result.data.message || "");
            messageEl.className = "text-base leading-relaxed";
            messageEl.style.color = "var(--text-secondary)";

            entryWrapper.appendChild(header);
            entryWrapper.appendChild(messageEl);

            entriesContainer.prepend(entryWrapper);

            // Remove the last entry if there are more than ENTRIES_PER_PAGE items
            const entries = entriesContainer.children;
            if (entries.length > ENTRIES_PER_PAGE) {
                entries[entries.length - 1].remove();
            }
        } else {
            // Fetch page 1 entries and replace the container content
            try {
                const response = await fetch("/api/guestbook-entries?page=1");
                const data = await response.json();

                if (data.entries) {
                    entriesContainer.innerHTML = data.entries
                        .map(
                            (entry: any) => `
                        <div class="p-6 sm:p-8 rounded-lg border transition-all hover:shadow-md" style="border-color: var(--border); background: var(--bg-secondary);">
                            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-2 pb-4">
                                <h3 class="font-display text-lg sm:text-xl font-bold" style="color: var(--text-primary);">${sanitize(entry.name)}</h3>
                                <span class="guestbook-date text-xs sm:text-sm" style="color: var(--text-tertiary);" data-iso="${entry.createdAt}"></span>
                            </div>
                            <p class="text-base leading-relaxed" style="color: var(--text-secondary);">${sanitize(entry.message, true)}</p>
                        </div>
                    `,
                        )
                        .join("");

                    // Update URL without reloading
                    window.history.pushState({}, "", "/guestbook");
                }
            } catch (error) {
                console.error("Failed to fetch page 1 entries:", error);
            }
        }

        setTimeout(() => {
            formError.textContent = "";
        }, 3000);
    });
</script>
