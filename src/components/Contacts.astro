---
import { Icon } from "astro-icon/components";
import IconTooltip from "./IconTooltip";
---

<div class="flex sm:justify-end gap-5">
    <IconTooltip label="GitHub" client:idle>
        <a
            aria-label="Github"
            href="https://github.com/a4ye/"
            target="_blank"
            rel="noreferrer noopener"
            class="transition-all duration-200 hover:scale-110"
            style="color: var(--text-tertiary);"
        >
            <Icon
                name="lucide--github"
                class="w-5 h-5 hover:opacity-70"
            />
        </a>
    </IconTooltip>
    <IconTooltip label="LinkedIn" client:idle>
        <a
            aria-label="LinkedIn"
            href="https://www.linkedin.com/in/aaron--ye"
            target="_blank"
            rel="noreferrer noopener"
            class="transition-all duration-200 hover:scale-110"
            style="color: var(--text-tertiary);"
        >
            <Icon
                name="lucide--linkedin"
                class="w-5 h-5 hover:opacity-70"
            />
        </a>
    </IconTooltip>
    <IconTooltip label="X" client:idle>
        <a
            aria-label="X"
            href="https://x.com/aaronye1001"
            target="_blank"
            rel="noreferrer noopener"
            class="transition-all duration-200 hover:scale-110"
            style="color: var(--text-tertiary);"
        >
            <Icon
                name="ri--twitter-x-line"
                class="w-5 h-5 hover:opacity-70"
            />
        </a>
    </IconTooltip>
    <IconTooltip label="Email" client:idle>
        <a
            aria-label="Email"
            href="mailto:aaronye1001@gmail.com"
            target="_blank"
            rel="noreferrer noopener"
            class="transition-all duration-200 hover:scale-110"
            style="color: var(--text-tertiary);"
        >
            <Icon
                name="lucide--mail"
                class="w-5 h-5 hover:opacity-70"
            />
        </a>
    </IconTooltip>
    <IconTooltip label="Resume" client:idle>
        <a
            aria-label="Resume"
            href="/resume"
            target="_blank"
            rel="noreferrer noopener"
            class="transition-all duration-200 hover:scale-110"
            style="color: var(--text-tertiary);"
        >
            <Icon
                name="lucide--file-text"
                class="w-5 h-5 hover:opacity-70"
            />
        </a>
    </IconTooltip>
</div>
