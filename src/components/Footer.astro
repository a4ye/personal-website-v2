---
import GithubCommit from "../components/GithubCommit.astro";
import VisitsCounter from "./VisitsCounter.astro";
import SpringToggle from "./SpringToggle.svelte";
import ThemeToggle from "./ThemeToggle.svelte";
import IconTooltip from "./IconTooltip";
const currentYear = new Date().getFullYear();
---

<footer class="w-full px-6 sm:px-12 md:px-20 pt-20 pb-8 border-t" style="border-color: var(--border);">
    <div class="flex flex-col sm:flex-row gap-8 sm:items-center justify-between">
        <div style="color: var(--text-tertiary); font-size: 0.875rem;">
            <p>© {currentYear} Aaron Ye. Built with Astro.</p>
        </div>
        <div class="flex items-center gap-8">
            <div class="flex items-center gap-4">
                <IconTooltip label="Toggle theme" client:idle>
                    <ThemeToggle client:idle />
                </IconTooltip>
                <IconTooltip label="Toggle petals" client:idle>
                    <SpringToggle client:idle />
                </IconTooltip>
            </div>
            <div class="flex items-center gap-4">
                <GithubCommit />
                <VisitsCounter />
            </div>
        </div>
    </div>
</footer>
