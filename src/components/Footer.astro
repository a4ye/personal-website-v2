---
import GithubCommit from "../components/GithubCommit.astro";
import VisitsCounter from "./VisitsCounter.astro";

const currentYear = new Date().getFullYear();
---

<footer class="w-full bg-surface">
    <div class="h-px bg-line"></div>
    <div class="max-w-6xl mx-auto px-6 md:px-10 py-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm text-muted">
        <span>© {currentYear} Aaron Ye</span>
        <div class="flex items-center gap-4">
            <GithubCommit />
            <span class="text-line">|</span>
            <VisitsCounter />
        </div>
    </div>
</footer>
