---
import NavLinks from "./NavLinks.svelte";
import Contacts from "./Contacts.astro";
const currentPath = Astro.url.pathname;
---

<!-- Navigation header -->
<div class="py-6 sm:py-8 animate-fadeIn">
    <!-- Mobile layout -->
    <div class="flex flex-col items-center gap-6 sm:hidden px-6">
        <a
            href="/"
            class="text-3xl font-display font-bold hover:text-accent-blue transition-colors duration-300"
            style="color: var(--text-primary);"
        >
            Aaron
        </a>
        <nav>
            <NavLinks currentPath={currentPath} client:idle />
        </nav>
        <Contacts />
    </div>

    <!-- Desktop layout -->
    <div class="hidden sm:flex justify-between items-center px-12 md:px-20">
        <a
            href="/"
            class="text-3xl md:text-4xl font-display font-bold hover:text-accent-blue transition-colors duration-300"
            style="color: var(--text-primary);"
        >
            Aaron
        </a>
        <div class="flex items-center gap-12">
            <nav>
                <NavLinks currentPath={currentPath} client:idle />
            </nav>
            <Contacts />
        </div>
    </div>
</div>
