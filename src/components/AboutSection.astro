---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import ottoLabsLogo from "../assets/logos/ottolabs.png";
import uwaterlooLogo from "../assets/logos/uwaterloo.svg";
import eurekahacksLogo from "../assets/logos/eurekahacks2025.svg";
import counterspell from "../assets/logos/counterspell.png";
import HackathonList from "./HackathonList.astro";
---

<section class="text-lg leading-[1.7] text-base">
    <h1 class="font-serif text-[2rem] font-normal text-accent mb-4">About Me</h1>
    <p class="mb-10 max-w-2xl">
        I'm a first-year CS student at the University of Waterloo pursuing software engineering. I
        have experience building full-stack applications, with a focus on backend systems.
    </p>

    <h2 class="font-serif text-2xl font-normal text-accent mt-10 mb-5">Currently</h2>
    <ul class="list-none p-0 m-0 flex flex-col gap-3">
        <li class="flex items-center gap-3">
            <Icon
                name="iconamoon--arrow-right-2-bold"
                class="w-4 h-4 text-accent shrink-0"
                aria-hidden="true"
            />
            <span
                >Software Engineering Intern @
                <Image
                    src={ottoLabsLogo}
                    alt="Otto Labs"
                    class="w-4 h-4 inline-block align-middle mx-1"
                />
                <a
                    href="https://ottosr.com/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-base underline decoration-line underline-offset-2 transition-colors duration-200 hover:decoration-base"
                    >Otto Labs</a
                >
            </span>
        </li>
        <li class="flex items-center gap-3">
            <Icon
                name="iconamoon--arrow-right-2-bold"
                class="w-4 h-4 text-accent shrink-0"
                aria-hidden="true"
            />
            <span
                >Studying Computer Science @
                <Image
                    src={uwaterlooLogo}
                    alt="UWaterloo"
                    class="w-4 h-4 inline-block align-middle mx-1"
                />
                <a
                    href="https://uwaterloo.ca/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-base underline decoration-line underline-offset-2 transition-colors duration-200 hover:decoration-base"
                    >UWaterloo</a
                >
            </span>
        </li>
        <li class="flex items-center gap-3">
            <Icon
                name="iconamoon--arrow-right-2-bold"
                class="w-4 h-4 text-accent shrink-0"
                aria-hidden="true"
            />
            <span>Learning about machine learning, AI, and systems programming</span>
        </li>
    </ul>

    <h2 class="font-serif text-2xl font-normal text-accent mt-10 mb-5">Previously</h2>
    <ul class="list-none p-0 m-0 flex flex-col gap-3">
        <HackathonList />
        <li class="flex items-center gap-3">
            <Icon
                name="iconamoon--arrow-right-2-bold"
                class="w-4 h-4 text-accent shrink-0"
                aria-hidden="true"
            />
            <span
                >Director of Tech @
                <Image
                    src={eurekahacksLogo}
                    alt="EurekaHACKS"
                    class="w-4 h-4 inline-block align-middle mx-1"
                />
                <a
                    href="https://2025.eurekahacks.ca/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-base underline decoration-line underline-offset-2 transition-colors duration-200 hover:decoration-base"
                    >EurekaHACKS</a
                >
            </span>
        </li>
        <li class="flex items-center gap-3">
            <Icon
                name="iconamoon--arrow-right-2-bold"
                class="w-4 h-4 text-accent shrink-0"
                aria-hidden="true"
            />
            <span
                >Organizer @
                <Image
                    src={counterspell}
                    alt="Counterspell"
                    class="w-4 h-4 inline-block align-middle mx-1"
                />
                <a
                    href="https://counterspell.hackclub.com/toronto"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-base underline decoration-line underline-offset-2 transition-colors duration-200 hover:decoration-base"
                    >Counterspell Toronto</a
                >
            </span>
        </li>
    </ul>
</section>
